#!/bin/bash
# Custom AppRun: put the bundled yt-dlp on PATH (so the app + mpv's ytdl hook
# find it). Qt plugins/libs are resolved via qt.conf + RUNPATH, so nothing else
# is needed here.
HERE="$(dirname "$(readlink -f "${0}")")"
export PATH="${HERE}/usr/bin:${PATH}"
# Make the bundled Breeze icon theme discoverable, and flag that we're running
# bundled so the app picks the theme/style itself (no KDE integration here).
export XDG_DATA_DIRS="${HERE}/usr/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
export FREEFLUME_APPIMAGE=1
exec "${HERE}/usr/bin/freeflume" "$@"
